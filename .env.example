# generate a random secret: https://generate-secret.vercel.app/32 or `openssl rand -base64 32`
AUTH_SECRET=****

# Auth.js site URL configuration
# Set these to the browser-facing public origin in production.
# Example production value: https://chat.example.com
# For local development, use http://localhost:3000 instead.
AUTH_URL=https://chat.example.com
NEXTAUTH_URL=https://chat.example.com
# Optional: internal URL used by the server when the public domain sits behind a reverse proxy or CDN
# Example: NEXTAUTH_URL_INTERNAL=http://127.0.0.1:3000
# Optional: comma-separated host[:port] allowlist for Next.js Server Actions
# Example: SERVER_ACTIONS_ALLOWED_ORIGINS=chat.example.com

# LiteLLM Responses API configuration
# Used by the default OpenAI-compatible endpoint when a model does not override endpoint_name.
LITELLM_BASE_URL=http://localhost:4000/v1
LITELLM_API_KEY=****

# Optional: default selected model and title model.
# Model IDs must exist in models.yaml.
LITELLM_DEFAULT_MODEL=volcengine/doubao-seed-2-0-mini-260215
LITELLM_TITLE_MODEL=volcengine/doubao-seed-2-0-mini-260215

# Optional: JSON object keyed by model ID, used to override capabilities from models.yaml
# Tool execution is disabled in the Responses API integration.
# Example: {"openai/gpt-4o-mini":{"tools":false,"vision":true,"reasoning":false}}
LITELLM_MODEL_CAPABILITIES=****

# RustFS storage configuration
# Public base URL should point to a public HTTPS path-style RustFS endpoint when vision models need to fetch images
RUSTFS_S3_ENDPOINT=http://127.0.0.1:9000
RUSTFS_S3_REGION=us-east-1
RUSTFS_S3_ACCESS_KEY=rustfsadmin
RUSTFS_S3_SECRET_KEY=rustfssecret
RUSTFS_S3_BUCKET=chatbot-uploads
RUSTFS_PUBLIC_BASE_URL=http://127.0.0.1:9000
RUSTFS_S3_FORCE_PATH_STYLE=true
# Optional: disable if public access is managed outside RustFS bucket policy
RUSTFS_S3_PUBLIC_READ_POLICY=true

# https://vercel.com/docs/postgres
POSTGRES_URL=****

# Redis connection string. Keep this password in sync with Redis `--requirepass`.
REDIS_URL=redis://:change-this-redis-password@127.0.0.1:6379
