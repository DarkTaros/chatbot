# generate a random secret: https://generate-secret.vercel.app/32 or `openssl rand -base64 32`
AUTH_SECRET=****

# LiteLLM Responses API configuration
LITELLM_BASE_URL=http://localhost:4000/v1
LITELLM_API_KEY=****

# Optional: default selected model and title model.
# Available models are read from LiteLLM Proxy's /models endpoint.
LITELLM_DEFAULT_MODEL=gpt-4o-mini
LITELLM_TITLE_MODEL=gpt-4o-mini

# Optional: JSON object keyed by model ID
# Tool execution is disabled in the Responses API integration.
# Example: {"gpt-4o-mini":{"tools":false,"vision":true,"reasoning":false}}
LITELLM_MODEL_CAPABILITIES=****

# RustFS storage configuration
# Public base URL should point to a public HTTPS path-style RustFS endpoint when vision models need to fetch images
RUSTFS_S3_ENDPOINT=http://127.0.0.1:9000
RUSTFS_S3_REGION=us-east-1
RUSTFS_S3_ACCESS_KEY=rustfsadmin
RUSTFS_S3_SECRET_KEY=rustfssecret
RUSTFS_S3_BUCKET=chatbot-uploads
RUSTFS_PUBLIC_BASE_URL=http://127.0.0.1:9000
RUSTFS_S3_FORCE_PATH_STYLE=true
# Optional: disable if public access is managed outside RustFS bucket policy
RUSTFS_S3_PUBLIC_READ_POLICY=true

# https://vercel.com/docs/postgres
POSTGRES_URL=****

# https://vercel.com/docs/redis
REDIS_URL=****
