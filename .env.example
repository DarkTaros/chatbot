# generate a random secret: https://generate-secret.vercel.app/32 or `openssl rand -base64 32`
AUTH_SECRET=****

# OpenAI Responses API configuration
OPENAI_API_KEY=****
# Optional: set only when using a compatible proxy that supports /v1/responses
OPENAI_BASE_URL=https://api.openai.com/v1

# Backward-compatible fallback values. OPENAI_API_KEY / OPENAI_BASE_URL take precedence.
OPENAI_COMPATIBLE_BASE_URL=****
OPENAI_COMPATIBLE_API_KEY=****

# Optional: provider name used by the AI SDK
OPENAI_COMPATIBLE_PROVIDER_NAME=openai

# Optional: comma-separated model IDs shown in the UI
OPENAI_COMPATIBLE_MODEL_IDS=gpt-4o-mini,gpt-4.1-mini

# Optional: default selected model and title model
OPENAI_COMPATIBLE_DEFAULT_MODEL=gpt-4o-mini
OPENAI_COMPATIBLE_TITLE_MODEL=gpt-4o-mini

# Optional: JSON object keyed by model ID
# Example: {"gpt-4o-mini":{"tools":true,"vision":true,"reasoning":false}}
OPENAI_COMPATIBLE_MODEL_CAPABILITIES=****

# Optional: set to false to fall back to the legacy AI SDK server stream path
OPENAI_RESPONSES_STREAMING=true

# RustFS storage configuration
# Public base URL should point to a public HTTPS path-style RustFS endpoint when vision models need to fetch images
RUSTFS_S3_ENDPOINT=http://127.0.0.1:9000
RUSTFS_S3_REGION=us-east-1
RUSTFS_S3_ACCESS_KEY=rustfsadmin
RUSTFS_S3_SECRET_KEY=rustfssecret
RUSTFS_S3_BUCKET=chatbot-uploads
RUSTFS_PUBLIC_BASE_URL=http://127.0.0.1:9000
RUSTFS_S3_FORCE_PATH_STYLE=true
# Optional: disable if public access is managed outside RustFS bucket policy
RUSTFS_S3_PUBLIC_READ_POLICY=true

# https://vercel.com/docs/postgres
POSTGRES_URL=****

# https://vercel.com/docs/redis
REDIS_URL=****
